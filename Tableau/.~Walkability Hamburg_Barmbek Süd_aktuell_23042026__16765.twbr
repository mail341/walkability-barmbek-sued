  <dashboards>
    <dashboard enable-sort-zone-taborder='true' name='Dashboard  02'>
      <style>
        <style-rule element='table'>
          <format attr='background-color' value='#fef05c1b' />
        </style-rule>
      </style>
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' preset-index='0' sizing-mode='fixed' />
      <zones>
        <zone h='33464' id='12' name='Barmbek-Süd District Boundary' w='31479' x='67936' y='69271' />
        <zone h='59505' id='7' is-centered='0' is-scaled='1' param='Image/mann geht 01.png' type-v2='bitmap' w='63104' x='366' y='1302'>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='background-color' value='#fef05c1b' />
          </zone-style>
        </zone>
        <zone forceUpdate='true' h='24740' id='5' type-v2='text' w='34114' x='36823' y='29688'>
          <formatted-text>
            <run fontcolor='#000000' fontname='Tableau Bold' fontsize='16'>THIS PROJECT AIMS TO</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Evaluate walkability in Barmbek-Süd</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Identify spatial patterns</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Understand key influencing factors</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Assess distribution and inequalities</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='23958' id='6' type-v2='text' w='28843' x='69912' y='1172'>
          <formatted-text>
            <run fontalignment='2' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Walking represents the first and last segment of most urban mobility chains.</run>
            <run fontalignment='2'>Æ&#10;</run>
            <run fontalignment='2' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>It refers to how easily and safely people can move through an urban environment on foot. It is a key factor for sustainable cities, influencing accessibility, public health, and quality of life.</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='23177' id='3' type-v2='text' w='25476' x='36896' y='3776'>
          <formatted-text>
            <run fontcolor='#555555' fontname='Tableau Semibold' fontsize='48'>PROJECT</run>
            <run>Æ&#10;</run>
            <run fontcolor='#555555' fontname='Tableau Semibold' fontsize='48'>OBJECTIVE</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='40495' id='8' type-v2='text' w='51903' x='732' y='68880'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>H 1 - Spatial Distribution</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>Walkability is not evenly distributed within Barmbek-Süd.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>H2 – Infrastructure Effect</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>Areas with better access to infrastructure (e.g. public transport, crossings, green spaces) show higher walkability scores.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>H3 – Combined Drivers</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>Walkability is influenced by both street characteristics and surrounding infrastructure.</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='12240' id='9' type-v2='text' w='36603' x='366' y='62109'>
          <formatted-text>
            <run fontcolor='#555555' fontname='Tableau Semibold' fontsize='48'>HYPOTHESIS</run>
          </formatted-text>
        </zone>
        <zone h='39453' id='10' name='Map Hamburg Overview' w='31552' x='67936' y='28125' />
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='1200' minheight='1200' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='16' type-v2='layout-basic' w='100000' x='0' y='0'>
              <zone h='97916' id='15' param='vert' type-v2='layout-flow' w='98828' x='586' y='1042'>
                <zone forceUpdate='true' h='23958' id='6' type-v2='text' w='28843' x='69912' y='1172'>
                  <formatted-text>
                    <run fontalignment='2' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>Walking represents the first and last segment of most urban mobility chains.</run>
                    <run fontalignment='2'>Æ&#10;</run>
                    <run fontalignment='2' fontcolor='#000000' fontname='Tableau Light' fontsize='12'>It refers to how easily and safely people can move through an urban environment on foot. It is a key factor for sustainable cities, influencing accessibility, public health, and quality of life.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='59505' id='7' is-centered='0' is-fixed='true' is-scaled='1' param='Image/mann geht 01.png' type-v2='bitmap' w='63104' x='366' y='1302'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#fef05c1b' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='23177' id='3' type-v2='text' w='25476' x='36896' y='3776'>
                  <formatted-text>
                    <run fontcolor='#555555' fontname='Tableau Semibold' fontsize='48'>PROJECT</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#555555' fontname='Tableau Semibold' fontsize='48'>OBJECTIVE</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
