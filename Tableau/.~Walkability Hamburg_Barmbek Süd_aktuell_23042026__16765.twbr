                  </zone-style>
                </zone>
                <zone fixed-size='280' h='39453' id='10' is-fixed='true' name='Map Hamburg Overview' w='31552' x='67936' y='28125'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='24740' id='5' type-v2='text' w='34114' x='36823' y='29688'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Tableau Bold' fontsize='16'>THIS PROJECT AIMS TO</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Evaluate walkability in Barmbek-Süd</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Identify spatial patterns</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Understand key influencing factors</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>- Assess distribution and inequalities</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='12240' id='9' type-v2='text' w='36603' x='366' y='62109'>
                  <formatted-text>
                    <run fontcolor='#555555' fontname='Tableau Semibold' fontsize='48'>HYPOTHESIS</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='40495' id='8' type-v2='text' w='51903' x='732' y='68880'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>H 1 - Spatial Distribution</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>Walkability is not evenly distributed within Barmbek-Süd.</run>
                    <run>Æ&#10;&#10;</run>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>H2 – Infrastructure Effect</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>Areas with better access to infrastructure (e.g. public transport, crossings, green spaces) show higher walkability scores.</run>
                    <run>Æ&#10;&#10;</run>
                    <run bold='true' fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>H3 – Combined Drivers</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Tableau Regular' fontsize='14'>Walkability is influenced by both street characteristics and surrounding infrastructure.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
